# Copie este arquivo para .env e preencha.

# OBRIGATÓRIA para a análise da IA. Crie em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OPCIONAL. Notícias com voto da comunidade (viés alta/baixa). Prioridade máxima.
# https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=

# OPCIONAL. Notícias agregadas de muitas fontes (chave grátis). Usada se não houver
# CryptoPanic. Sem nenhuma das duas, o app usa RSS gratuito (funciona bem).
# https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_KEY=

# Senha compartilhada para acessar o app quando publicado (você, seus sócios).
# Se ficar vazia, o app fica ABERTO (ok só em localhost). Defina no Render.
APP_PASSWORD=

PORT=3001
